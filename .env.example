# Dev mode:
# - local: Android emulator -> 10.0.2.2, iOS simulator -> localhost
# - deploy: call EXPO_PUBLIC_API_SERVER in dev
EXPO_PUBLIC_API_ENV=local

# Deploy URL (also used by release build)
EXPO_PUBLIC_API_SERVER=https://edubridgehcm.onrender.com

# Optional: set when testing on physical device (use your LAN IP)
# EXPO_PUBLIC_API_LOCAL=http://192.168.1.10:8080

# Optional: hard override all logic above
# EXPO_PUBLIC_API_BASE=
